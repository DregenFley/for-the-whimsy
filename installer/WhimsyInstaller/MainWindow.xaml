<Window x:Class="WhimsyInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="For the Whimsy — Installer"
        Height="520" Width="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#faf6ee"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4a7c3f"/>
            <Setter Property="Foreground" Value="#e8f5de"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3a6030"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2d4a25"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#c9b99a"/>
                                <Setter Property="Foreground" Value="#f5efe3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7a6a52"/>
            <Setter Property="BorderBrush" Value="#c9b99a"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#f0ebe0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#3a2e1e" CornerRadius="0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Canvas Width="36" Height="36" VerticalAlignment="Center">
                    <Ellipse Canvas.Left="0" Canvas.Top="0" Width="36" Height="36" Fill="#4a3520"/>
                    <Path Data="M18 4 C12 4 9 9 9 14 C9 17 10.2 19 12 20.5 L12 28 L24 28 L24 20.5 C25.8 19 27 17 27 14 C27 9 24 4 18 4Z" Fill="#5a8a3a"/>
                    <Path Data="M15 28 L21 28 L21 30.5 C21 31 20.6 31.5 20 31.5 L16 31.5 C15.4 31.5 15 31 15 30.5Z" Fill="#3a5e28"/>
                    <Ellipse Canvas.Left="28" Canvas.Top="8" Width="4" Height="4" Fill="#f5c842" Opacity="0.8"/>
                    <Ellipse Canvas.Left="8" Canvas.Top="18" Width="3" Height="3" Fill="#f5c842" Opacity="0.6"/>
                    <Ellipse Canvas.Left="29" Canvas.Top="19" Width="2.5" Height="2.5" Fill="#f5c842" Opacity="0.5"/>
                </Canvas>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="For the Whimsy" FontSize="15" FontWeight="Medium" Foreground="#e8dcc8"/>
                    <TextBlock Text="modpack installer" FontSize="10" Foreground="#8a7055"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,14,16,14" x:Name="MainPanel">

                <!-- Version Info Cards -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#f0ebe0" BorderBrush="#d4c4a8" BorderThickness="0.5" CornerRadius="8" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="INSTALLED" FontSize="10" Foreground="#a09070" LetterSpacing="1"/>
                            <TextBlock x:Name="InstalledVersionText" Text="—" FontSize="20" FontWeight="Medium" Foreground="#3a2e1e" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#f0ebe0" BorderBrush="#d4c4a8" BorderThickness="0.5" CornerRadius="8" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="LATEST" FontSize="10" Foreground="#a09070" LetterSpacing="1"/>
                            <TextBlock x:Name="LatestVersionText" Text="..." FontSize="20" FontWeight="Medium" Foreground="#4a7c3f" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Status / Changelog Banner -->
                <Border x:Name="StatusBanner" Background="#f0ebe0" BorderBrush="#d4c4a8" BorderThickness="0.5" CornerRadius="8" Padding="12,10" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#EF9F27" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock x:Name="BannerTitle" Text="Checking for updates..." FontSize="12" FontWeight="Medium" Foreground="#3a2e1e"/>
                            <TextBlock x:Name="BannerSubtitle" Text="" FontSize="11" Foreground="#7a6a52" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Progress -->
                <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,0,0,12">
                    <Grid Margin="0,0,0,5">
                        <TextBlock x:Name="ProgressLabel" Text="Downloading..." FontSize="11" Foreground="#7a6a52"/>
                        <TextBlock x:Name="ProgressPercent" Text="0%" FontSize="11" Foreground="#4a7c3f" HorizontalAlignment="Right"/>
                    </Grid>
                    <Border Background="#e8dfc8" CornerRadius="99" Height="5">
                        <Border x:Name="ProgressBar" Background="#6aaa4a" CornerRadius="99" HorizontalAlignment="Left" Width="0"/>
                    </Border>
                </StackPanel>

                <!-- Log Output -->
                <Border x:Name="LogPanel" Background="#f5f0e6" BorderBrush="#ddd0b8" BorderThickness="0.5" CornerRadius="8" Padding="12,10" Margin="0,0,0,12" Visibility="Collapsed">
                    <StackPanel x:Name="LogStack">
                        <TextBlock x:Name="LogLine1" FontSize="11" Foreground="#7a6a52" FontFamily="Consolas"/>
                        <TextBlock x:Name="LogLine2" FontSize="11" Foreground="#7a6a52" FontFamily="Consolas"/>
                        <TextBlock x:Name="LogLine3" FontSize="11" Foreground="#4a7c3f" FontFamily="Consolas"/>
                    </StackPanel>
                </Border>

                <!-- JourneyMap Prompt -->
                <Border x:Name="JourneyMapPanel" Background="#f0ebe0" BorderBrush="#c9b99a" BorderThickness="0.5" CornerRadius="10" Padding="14,12" Margin="0,0,0,12" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Keep your old map data?" FontSize="13" FontWeight="Medium" Foreground="#3a2e1e" Margin="0,0,0,5"/>
                        <TextBlock Text="JourneyMap data from your previous install was found. Keep it if the server world hasn't changed — or start fresh if it has." FontSize="11" Foreground="#7a6a52" TextWrapping="Wrap" LineHeight="17" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="KeepMapButton" Content="Keep my map" Style="{StaticResource PrimaryButton}" Click="KeepMapButton_Click"/>
                            <Button Grid.Column="2" x:Name="FreshMapButton" Content="Start fresh" Style="{StaticResource SecondaryButton}" Click="FreshMapButton_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Main Action Button -->
                <Button x:Name="ActionButton" Content="Checking..." Style="{StaticResource PrimaryButton}" IsEnabled="False" Click="ActionButton_Click" Margin="0,0,0,0"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#f5efe3" BorderBrush="#e0d4be" BorderThickness="0,0.5,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                <Ellipse Width="6" Height="6" x:Name="StatusDot" Fill="#6aaa4a" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="FooterText" Text="connecting..." FontSize="10" Foreground="#a09070" FontFamily="Consolas" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
