<Window x:Class="WhimsyInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="For the Whimsy — Setup"
        Height="560" Width="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#faf6ee"
        FontFamily="Segoe UI"
        Icon="app.ico">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4a7c3f"/>
            <Setter Property="Foreground" Value="#e8f5de"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3a6030"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2d4a25"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#c9b99a"/>
                                <Setter Property="Foreground" Value="#f5efe3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7a6a52"/>
            <Setter Property="BorderBrush" Value="#c9b99a"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#f0ebe0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WhimsyCheckBox" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#3a2e1e"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                            <Border x:Name="Box" Width="16" Height="16" CornerRadius="4"
                                    Background="#faf6ee" BorderBrush="#c9b99a" BorderThickness="1"
                                    Margin="0,1,8,0" VerticalAlignment="Top">
                                <TextBlock x:Name="Tick" Text="✓" FontSize="11" Foreground="#4a7c3f"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Top"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#e8f0de"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#4a7c3f"/>
                                <Setter TargetName="Tick" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#4a7c3f"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#3a2e1e" CornerRadius="0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Canvas Width="36" Height="36" VerticalAlignment="Center">
                    <Ellipse Canvas.Left="0" Canvas.Top="0" Width="36" Height="36" Fill="#4a3520"/>
                    <Ellipse Canvas.Left="12.5" Canvas.Top="5.5" Width="11" Height="11" Fill="#7a4ea8"/>
                    <Ellipse Canvas.Left="19.5" Canvas.Top="10.5" Width="11" Height="11" Fill="#7a4ea8"/>
                    <Ellipse Canvas.Left="16.5" Canvas.Top="18.5" Width="11" Height="11" Fill="#7a4ea8"/>
                    <Ellipse Canvas.Left="8.5"  Canvas.Top="18.5" Width="11" Height="11" Fill="#7a4ea8"/>
                    <Ellipse Canvas.Left="5.5"  Canvas.Top="10.5" Width="11" Height="11" Fill="#7a4ea8"/>
                    <Ellipse Canvas.Left="13" Canvas.Top="6"  Width="10" Height="10" Fill="#a57cc9"/>
                    <Ellipse Canvas.Left="20" Canvas.Top="11" Width="10" Height="10" Fill="#a57cc9"/>
                    <Ellipse Canvas.Left="17" Canvas.Top="19" Width="10" Height="10" Fill="#a57cc9"/>
                    <Ellipse Canvas.Left="9"  Canvas.Top="19" Width="10" Height="10" Fill="#a57cc9"/>
                    <Ellipse Canvas.Left="6"  Canvas.Top="11" Width="10" Height="10" Fill="#a57cc9"/>
                    <Ellipse Canvas.Left="14" Canvas.Top="14" Width="8" Height="8" Fill="#f5c842"/>
                    <Ellipse Canvas.Left="30" Canvas.Top="5"  Width="3"   Height="3"   Fill="#f5c842" Opacity="0.7"/>
                    <Ellipse Canvas.Left="3"  Canvas.Top="29" Width="2.5" Height="2.5" Fill="#f5c842" Opacity="0.5"/>
                </Canvas>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="For the Whimsy" FontSize="15" FontWeight="Medium" Foreground="#e8dcc8"/>
                    <TextBlock Text="profile setup tool" FontSize="10" Foreground="#8a7055"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,14,16,14">

                <!-- Status Banner -->
                <Border x:Name="StatusBanner" Background="#f0ebe0" BorderBrush="#d4c4a8" BorderThickness="0.5" CornerRadius="8" Padding="12,10" Margin="0,0,0,12" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="BannerDot" Width="8" Height="8" Fill="#6aaa4a" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock x:Name="BannerTitle" FontSize="12" FontWeight="Medium" Foreground="#3a2e1e"/>
                            <TextBlock x:Name="BannerSubtitle" FontSize="11" Foreground="#7a6a52" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- FROM -->
                <Border Background="#f0ebe0" BorderBrush="#c9b99a" BorderThickness="0.5" CornerRadius="10" Padding="14,12" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="COPY FROM" FontSize="10" Foreground="#a09070" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="SourceDropdown" Grid.Column="0"
                                      FontSize="12" Padding="8,6"
                                      DisplayMemberPath="DisplayName"
                                      SelectionChanged="SourceDropdown_SelectionChanged"/>
                            <Button Grid.Column="1" Content="Browse…" Margin="6,0,0,0"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="10,0" Click="BrowseFolderButton_Click"/>
                        </Grid>
                        <TextBlock x:Name="InstancesPathHint" FontSize="9" Foreground="#a09070" FontStyle="Italic" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- WHAT TO COPY -->
                <Border Background="#f0ebe0" BorderBrush="#c9b99a" BorderThickness="0.5" CornerRadius="10" Padding="14,12" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="WHAT TO COPY" FontSize="10" Foreground="#a09070" Margin="0,0,0,10"/>

                        <CheckBox x:Name="JourneyMapCheck" IsChecked="True" Style="{StaticResource WhimsyCheckBox}">
                            <StackPanel>
                                <TextBlock Text="JourneyMap data" FontSize="12" Foreground="#3a2e1e"/>
                                <TextBlock Text="Your explored map and waypoints" FontSize="10" Foreground="#a09070"/>
                            </StackPanel>
                        </CheckBox>

                        <CheckBox x:Name="OptionsCheck" IsChecked="True" Style="{StaticResource WhimsyCheckBox}">
                            <StackPanel>
                                <TextBlock Text="Settings &amp; keybinds" FontSize="12" Foreground="#3a2e1e"/>
                                <TextBlock Text="Video settings, controls, and key bindings" FontSize="10" Foreground="#a09070"/>
                            </StackPanel>
                        </CheckBox>

                        <CheckBox x:Name="ServersCheck" IsChecked="True" Style="{StaticResource WhimsyCheckBox}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Server list" FontSize="12" Foreground="#3a2e1e"/>
                                <TextBlock Text="Your saved server connections" FontSize="10" Foreground="#a09070"/>
                            </StackPanel>
                        </CheckBox>
                    </StackPanel>
                </Border>

                <!-- INTO -->
                <Border Background="#f0ebe0" BorderBrush="#c9b99a" BorderThickness="0.5" CornerRadius="10" Padding="14,12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="INTO PROFILE" FontSize="10" Foreground="#a09070" Margin="0,0,0,6"/>
                        <ComboBox x:Name="DestDropdown" FontSize="12" Padding="8,6"
                                  DisplayMemberPath="DisplayName"/>
                    </StackPanel>
                </Border>

                <!-- Copy Button -->
                <Button x:Name="CopyButton" Content="Copy across" Style="{StaticResource PrimaryButton}" Click="CopyButton_Click"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#f5efe3" BorderBrush="#e0d4be" BorderThickness="0,0.5,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                <Ellipse Width="6" Height="6" x:Name="StatusDot" Fill="#6aaa4a" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="FooterText" Text="ready" FontSize="10" Foreground="#a09070" FontFamily="Consolas" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
